# Groq API Key (Get yours at https://console.groq.com/)
GROQ_API_KEY=your_groq_api_key_here

# Groq model to use (llama-3.3-70b-versatile is the best general model)
# Options:
#   llama-3.3-70b-versatile
#   llama-3.1-8b-instant
GROQ_MODEL=llama-3.3-70b-versatile

# Maximum tokens for the AI response
MAX_TOKENS=4096

# App settings
APP_HOST=0.0.0.0
APP_PORT=8000
