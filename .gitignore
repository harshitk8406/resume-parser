docs/_build/

# PyBuilder
.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or app, you might want to share your .python-version.
#   Only uncomment if you are using pyenv.
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates have different platforms or python versions,
#   this may cause conflict.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock can be submitted unless it's a library.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock can be submitted unless it's a library.
#.pdm.toml
#.pdm-plugins/
#pdm.lock

# PEP 582; global packages directory; list of requirements (virtualenv alternative)
#   Uncomment to ignore.
#__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Spyder project settings
.spyderproject
.spyproject

# VS Code settings
.vscode/

# PyCharm / JetBrains settings
.idea/

# Custom project ignores
test_output.docx
*.docx-temporary
